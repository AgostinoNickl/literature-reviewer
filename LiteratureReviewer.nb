      RowBox[{"quantErrorNorm", "=", "1"}], ";", "\[IndentingNewLine]", 
      RowBox[{"radius", "=", 
       RowBox[{"Max", "[", 
        RowBox[{"somX", ",", "somY"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"plateauChecks", "=", 
       RowBox[{"Max", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Floor", "[", 
           RowBox[{"ite", "/", "16"}], "]"}], ",", "2"}], "}"}], "]"}]}], ";",
       "\[IndentingNewLine]", 
      RowBox[{"quantErrors", "=", 
       RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"quantErrorNorms", "=", 
