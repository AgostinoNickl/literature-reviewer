              RowBox[{"guideBookAssoc", "[", 
               RowBox[{"[", 
                RowBox[{
                 RowBox[{"guideBookKeys", "[", 
                  RowBox[{"[", "g", "]"}], "]"}], ",", 
                 "\"\<file attachments\>\""}], "]"}], "]"}]}]}], ";", 
            "\[IndentingNewLine]", "\[IndentingNewLine]", 
            RowBox[{"(*", 
