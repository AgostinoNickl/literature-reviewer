     "errors"}], ",", 
    RowBox[{"and", " ", "optional", " ", "stat", " ", 
     RowBox[{"visualization", "/", 
      RowBox[{"export", "."}]}]}]}], "*)"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "Informed", " ", "by", " ", "code", " ", "from", " ", "ETHZ", " ", 
