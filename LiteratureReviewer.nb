                RowBox[{"x_", "/;", 
                 RowBox[{"x", ">", "3"}]}]}], "]"}]}], "]"}], "&"}], "@", 
           RowBox[{"StringTrim", "[", 
            RowBox[{"StringDelete", "[", 
             RowBox[{"strings", ",", "DigitCharacter"}], "]"}], "]"}]}]}], 
         "]"}]}]}]}]}], "\[IndentingNewLine]", "]"}]}]}]], "Input",
