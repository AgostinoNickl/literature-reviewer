             RowBox[{"Alternatives", "[", "numerals", "]"}], "~~", 
             RowBox[{"(", 
              RowBox[{
              "WhitespaceCharacter", "|", "EndOfString", "|", 
               "PunctuationCharacter"}], ")"}]}], ",", 
            RowBox[{"IgnoreCase", "->", "True"}]}], "]"}], ",", 
          "DigitCharacter"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"riffledLines", "=", 
