                RowBox[{"longestSeq", "[", 
                 RowBox[{"[", "i", "]"}], "]"}]}], "]"}], ",", 
              RowBox[{"{", 
               RowBox[{"i", ",", 
                RowBox[{"Length", "@", "longestSeq"}]}], "}"}]}], "]"}], ",", 
            "\"\<\>\""}], "]"}], ",", 
          RowBox[{
           RowBox[{
            RowBox[{"Extract", "[", 
             RowBox[{
              RowBox[{"Keys", "[", 
               RowBox[{"Counts", "[", "#", "]"}], "]"}], ",", 
              RowBox[{"Position", "[", 
               RowBox[{
                RowBox[{"Values", "[", 
