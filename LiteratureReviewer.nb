     "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"ToString", "@", "toDelete"}], "==", "\"\<{}\>\""}], ",", 
       "text", ",", "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
