         RowBox[{"ToString", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"Which", "[", "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"type", "==", "\"\<highlighted\>\""}], ",", 
             RowBox[{"Framed", "[", 
              RowBox[{
               RowBox[{"Style", "[", 
                RowBox[{"word", ",", 
                 RowBox[{"FontColor", "->", "White"}]}], "]"}], ",", 
               RowBox[{"Background", "->", "color"}], ",", 
