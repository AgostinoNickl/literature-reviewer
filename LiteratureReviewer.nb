       RowBox[{"-", "Trained"}], " ", "and", " ", "enriched", " ", "SOM", " ",
        "structure", " ", "with", " ", "added", " ", "guide", " ", 
       "words"}]}], ";", 
     RowBox[{"Description", ":", 
      RowBox[{
      "Creates", " ", "and", " ", "trains", " ", "a", " ", "SOM", " ", "grid",
        " ", "on", " ", "the", " ", "provided", " ", "vectors"}]}]}], ",", 
    RowBox[{
    "selects", " ", "the", " ", "best", " ", "SOM", " ", "iteration", " ", 
     "based", " ", "on", " ", "quantization", " ", "and", " ", "topographic", 
     " ", "error", " ", 
