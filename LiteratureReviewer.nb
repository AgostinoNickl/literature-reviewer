    RowBox[{
     RowBox[{
      RowBox[{"-", "periodicity"}], " ", "optional", " ", "boolean", " ", 
      "for", " ", "grid", " ", "periodicity", " ", 
      RowBox[{"(", 
       RowBox[{"default", " ", "True"}], ")"}]}], ";", 
     RowBox[{"Output", ":", 
