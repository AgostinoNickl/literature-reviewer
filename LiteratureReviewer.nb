             RowBox[{"Last", "@", 
              RowBox[{"#", "[", 
               RowBox[{"[", "2", "]"}], "]"}]}]}], "]"}]}], "&"}], "@", "#"}],
         ",", 
        RowBox[{"\"\<vector_ref\>\"", "->", 
