          RowBox[{"purgedTextList", "=", 
           RowBox[{
            RowBox[{
             RowBox[{"StringDelete", "[", 
              RowBox[{"text", ",", "#"}], "]"}], "&"}], "/@", "toDelete"}]}], 
          ";", "\[IndentingNewLine]", 
          RowBox[{"cleanedTextList", "=", 
           RowBox[{"StringTrim", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"StringReplace", "[", 
               RowBox[{"#", ",", 
