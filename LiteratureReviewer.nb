Cell[BoxData[
 RowBox[{
  RowBox[{"(*", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Input", ":", 
     RowBox[{
      RowBox[{"-", "x"}], " ", "number", " ", "of", " ", "1", "D", " ", "SOM",
       " ", "cells"}]}], ",", 
    RowBox[{
     RowBox[{"-", "guideVec"}], " ", "list", " ", "of", " ", "training", " ", 
     "input", " ", "vectors"}], ",", 
    RowBox[{
     RowBox[{"-", "somSelection"}], " ", "selection", " ", "mode", " ", 
     RowBox[{"(", 
      RowBox[{
      "\"\<Automatic\>\"", " ", "for", " ", "pick", " ", "based", " ", "on", 
       " ", 
       RowBox[{"TE", "/", "QE"}], " ", "or", " ", "\"\<Last\>\"", " ", "for", 
