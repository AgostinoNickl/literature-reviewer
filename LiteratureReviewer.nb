Cell[TextData[StyleBox["OpenCLIP (fast)",
 FontSize->15,
 FontVariations->{"Underline"->True},
 FontColor->RGBColor[0., 0., 0.]]], "Subsubsection",
 CellChangeTimes->{{3.9872324853174677`*^9, 3.987232502736926*^9}, {
  3.987232549939611*^9, 3.987232572324007*^9}, {3.987233514991962*^9, 
  3.987233521317048*^9}},ExpressionUUID->"aad144e6-0ad1-4d20-b2d2-\
347c3f70b182"],

Cell[BoxData[
 RowBox[{"textModel", "=", 
  RowBox[{"NetModel", "[", 
   RowBox[{"{", 
    RowBox[{
    "\"\<OpenCLIP Multi-domain Feature Extractor Trained on LAION-2B \
Data\>\"", ",", 
     RowBox[{"\"\<InputDomain\>\"", "->", "\"\<Text\>\""}], ",", 
     RowBox[{"\"\<Architecture\>\"", "->", "\"\<ViT-B/32\>\""}]}], "}"}], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.987233354267807*^9, 3.987233369651349*^9}, 
   3.987233466749387*^9, {3.987233723203541*^9, 3.987233723276409*^9}, 
