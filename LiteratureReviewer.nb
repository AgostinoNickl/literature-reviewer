             RowBox[{"IgnoreCase", "->", "True"}]}], "]"}], "&"}], "/@", 
          "zoteroAss"}], ",", "False"}], "]"}]}], ";", 
      RowBox[{"guideBookKeys", "=", 
       RowBox[{"Delete", "[", 
