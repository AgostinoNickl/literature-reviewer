        ",", "test2", ",", "pos1", ",", "pos2", ",", "pos", ",", "tokenKeys", 
       ",", "data"}], "}"}], ",", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
      "Case", " ", "all", " ", "keys", " ", "to", " ", "lower", " ", "case"}],
       "*)"}], "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"zoteroAss", "=", 
       RowBox[{
        RowBox[{
         RowBox[{"AssociationThread", "[", 
          RowBox[{
           RowBox[{"ToLowerCase", "@", 
            RowBox[{"First", "@", "zoteroCSV"}]}], ",", "#"}], "]"}], "&"}], "/@", 
        RowBox[{"Rest", "@", "zoteroCSV"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"guideBookAssoc", "=", 
       RowBox[{"FlattenAssociation", "[", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"Association", "[", 
           RowBox[{
            RowBox[{"zoteroAss", "[", 
             RowBox[{"[", 
              RowBox[{"i", ",", "\"\<key\>\""}], "]"}], "]"}], "->", 
            RowBox[{"zoteroAss", "[", 
             RowBox[{"[", "i", "]"}], "]"}]}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", 
            RowBox[{"Length", "@", "zoteroAss"}]}], "}"}]}], "]"}], "]"}]}], 
      ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"badPos", "=", 
       RowBox[{"Position", "[", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"StringEndsQ", "[", 
