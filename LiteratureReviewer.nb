                  ",", "\[IndentingNewLine]", 
                  RowBox[{
                   RowBox[{
                    RowBox[{
                    RowBox[{"sentences", "[", 
                    RowBox[{"[", "i", "]"}], "]"}], "[", 
                    RowBox[{"[", 
                    RowBox[{"Length", "@", 
                    RowBox[{"sentences", "[", 
                    RowBox[{"[", "i", "]"}], "]"}]}], "]"}], "]"}], "=", 
                    RowBox[{"StringRiffle", "[", 
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"sentences", "[", 
                    RowBox[{"[", "i", "]"}], "]"}], "[", 
                    RowBox[{"[", 
                    RowBox[{"Length", "@", 
                    RowBox[{"sentences", "[", 
                    RowBox[{"[", "i", "]"}], "]"}]}], "]"}], "]"}], ",", 
                    RowBox[{
                    RowBox[{"sentences", "[", 
                    RowBox[{"[", 
                    RowBox[{"i", "+", "1"}], "]"}], "]"}], "[", 
                    RowBox[{"[", "1", "]"}], "]"}]}], "}"}], "]"}]}], ";", 
                   "\[IndentingNewLine]", 
                   RowBox[{
                    RowBox[{"sentences", "[", 
                    RowBox[{"[", 
                    RowBox[{"i", "+", "1"}], "]"}], "]"}], "=", 
                    RowBox[{"Delete", "[", 
                    RowBox[{
                    RowBox[{"sentences", "[", 
                    RowBox[{"[", 
                    RowBox[{"i", "+", "1"}], "]"}], "]"}], ",", "1"}], 
                    "]"}]}]}], ",", "\"\<\>\""}], "]"}], ",", "\"\<\>\""}], 
               "]"}], ",", 
              RowBox[{"{", 
               RowBox[{"i", ",", 
                RowBox[{
                 RowBox[{"Length", "@", "sentences"}], "-", "1"}]}], "}"}]}], 
             "]"}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
            RowBox[{"Table", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"sentences", "[", 
                RowBox[{"[", "i", "]"}], "]"}], "=", 
               RowBox[{"Select", "[", 
                RowBox[{
                 RowBox[{"sentences", "[", 
                  RowBox[{"[", "i", "]"}], "]"}], ",", 
                 RowBox[{
                  RowBox[{
                   RowBox[{"StringLength", "[", "#", "]"}], ">=", 
                   "minStringLen"}], "&"}]}], "]"}]}], ",", 
              RowBox[{"{", 
               RowBox[{"i", ",", 
                RowBox[{"Length", "@", "sentences"}]}], "}"}]}], "]"}], ";", 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{"StringQ", "[", "searchTerm", "]"}], ",", 
              "\[IndentingNewLine]", 
              RowBox[{"Table", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"sentences", "[", 
                  RowBox[{"[", "i", "]"}], "]"}], "=", 
                 RowBox[{"Select", "[", 
                  RowBox[{
                   RowBox[{"sentences", "[", 
                    RowBox[{"[", "i", "]"}], "]"}], ",", 
                   RowBox[{
                    RowBox[{"StringContainsQ", "[", 
                    RowBox[{"#", ",", "searchTerm", ",", 
                    RowBox[{"IgnoreCase", "->", "True"}]}], "]"}], "&"}]}], 
                  "]"}]}], ",", 
                RowBox[{"{", 
                 RowBox[{"i", ",", 
                  RowBox[{"Length", "@", "sentences"}]}], "}"}]}], "]"}]}], 
             "]"}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
            RowBox[{"sentencesNoRef", "=", 
             RowBox[{"Table", "[", 
              RowBox[{
               RowBox[{"Table", "[", 
                RowBox[{
                 RowBox[{"Pick", "[", 
                  RowBox[{
                   RowBox[{"sentences", "[", 
                    RowBox[{"[", 
                    RowBox[{"i", ",", "j"}], "]"}], "]"}], ",", 
                   RowBox[{
                    RowBox[{"refClassifier", "[", 
                    RowBox[{"sentences", "[", 
                    RowBox[{"[", 
                    RowBox[{"i", ",", "j"}], "]"}], "]"}], "]"}], "==", 
                    "\"\<sentence\>\""}]}], "]"}], ",", 
                 RowBox[{"{", 
                  RowBox[{"j", ",", 
                   RowBox[{"Length", "@", 
                    RowBox[{"sentences", "[", 
                    RowBox[{"[", "i", "]"}], "]"}]}]}], "}"}]}], "]"}], ",", 
               RowBox[{"{", 
                RowBox[{"i", ",", 
                 RowBox[{"Length", "@", "sentences"}]}], "}"}]}], "]"}]}], 
            ";", "\[IndentingNewLine]", 
            RowBox[{"sentencesNoRefClean", "=", 
             RowBox[{"Table", "[", 
              RowBox[{
               RowBox[{
                RowBox[{
                 RowBox[{"Pick", "[", 
                  RowBox[{"#", ",", 
                   RowBox[{
                    RowBox[{
                    RowBox[{"DictWordCount", "[", "#", "]"}], ">", 
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{"Length", "[", 
                    RowBox[{"TextWordsFast", "[", "#", "]"}], "]"}], "/", 
                    "1.5"}], ")"}]}], "&&", 
                    RowBox[{
                    RowBox[{"DictWordCount", "[", "#", "]"}], ">=", "5"}]}]}],
                   "]"}], "&"}], "/@", 
                RowBox[{"sentencesNoRef", "[", 
                 RowBox[{"[", "i", "]"}], "]"}]}], ",", 
               RowBox[{"{", 
                RowBox[{"i", ",", 
                 RowBox[{"Length", "@", "sentencesNoRef"}]}], "}"}]}], 
              "]"}]}], ";", "\[IndentingNewLine]", 
            RowBox[{"sentencesFiltered", "=", 
             RowBox[{"Table", "[", 
              RowBox[{
               RowBox[{
                RowBox[{
                 RowBox[{"Pick", "[", 
                  RowBox[{"#", ",", 
                   RowBox[{
                    RowBox[{
                    RowBox[{"Length", "[", 
                    RowBox[{"TextWordsFast", "[", "#", "]"}], "]"}], ">", 
                    "10"}], "&&", 
                    RowBox[{
                    RowBox[{"Length", "[", 
                    RowBox[{"TextWordsFast", "[", "#", "]"}], "]"}], "<", 
                    "100"}]}]}], "]"}], "&"}], "/@", 
                RowBox[{"sentencesNoRefClean", "[", 
