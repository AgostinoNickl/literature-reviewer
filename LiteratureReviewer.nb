                 RowBox[{"partitions", "[", 
                  RowBox[{"[", "1", "]"}], "]"}], ",", 
                 RowBox[{"partitions", "[", 
                  RowBox[{"[", "#", "]"}], "]"}]}], "]"}], "&"}], "/@", 
              RowBox[{"Range", "[", 
               RowBox[{"2", ",", 
                RowBox[{"Length", "@", "partitions"}]}], "]"}]}]}]}], 
           "\[IndentingNewLine]", ",", 
