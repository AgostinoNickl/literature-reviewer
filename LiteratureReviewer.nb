   3.961252901133298*^9, 3.961252902829485*^9}, {3.9871668615796223`*^9, 
   3.987166867722102*^9}, {3.98717827216405*^9, 3.987178274376623*^9}, {
   3.987178522939116*^9, 3.987178523063135*^9}, {3.987178673015341*^9, 
