      "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"numerals", "=", 
       RowBox[{
        RowBox[{
         RowBox[{"ToString", "[", 
          RowBox[{"RomanNumeral", "[", "#", "]"}], "]"}], "&"}], "/@", 
