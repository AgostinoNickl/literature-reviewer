      "length", " ", "requirements"}], ";", 
     RowBox[{"Output", ":", 
      RowBox[{
       RowBox[{"-", "List"}], " ", "of", " ", 
       RowBox[{"{", 
        RowBox[{"vector", ",", "tokens", ",", "key"}], "}"}], " ", 
       "triples"}]}]}], ",", 
    RowBox[{"embedding", " ", "association"}], ",", 
    RowBox[{"sentence", " ", "association"}], ",", 
    RowBox[{
     RowBox[{"and", " ", "book", " ", "metadata", " ", "association"}], ";", 
     RowBox[{"Description", ":", 
