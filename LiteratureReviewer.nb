 CellLabel->"In[81]:=",ExpressionUUID->"d2759081-7025-4b69-a919-a84b240d71e4"]
}, Closed]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["RoBERTa (arguably better but slower)",
 FontSize->15,
 FontVariations->{"Underline"->True},
 FontColor->RGBColor[0., 0., 0.]]], "Subsubsection",
 CellChangeTimes->{{3.9872324853174677`*^9, 3.987232502736926*^9}, {
   3.987232715616337*^9, 3.987232715821752*^9}, 
   3.987233527827792*^9},ExpressionUUID->"092650d9-3291-447f-ac98-\
74bdfe9fd6f6"],

Cell[BoxData[
 RowBox[{"textModel", "=", 
  RowBox[{"NetGraph", "[", 
   RowBox[{
    RowBox[{"<|", 
     RowBox[{
      RowBox[{"\"\<model\>\"", "->", 
       RowBox[{
       "NetModel", "[", 
        "\"\<RoBERTa Trained on BookCorpus, English Wikipedia, CC-News, \
OpenWebText and Stories Datasets\>\"", "]"}]}], ",", 
      RowBox[{"\"\<pooling\>\"", "->", 
       RowBox[{"AggregationLayer", "[", 
        RowBox[{"Mean", ",", "1"}], "]"}]}], ",", 
      RowBox[{"\"\<normalize\>\"", "->", 
       RowBox[{"FunctionLayer", "[", 
        RowBox[{
         RowBox[{"#", "/", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Norm", "[", "#", "]"}], "+", 
            RowBox[{"10", "^", 
             RowBox[{"-", "12"}]}]}], ")"}]}], "&"}], "]"}]}]}], "|>"}], ",", 
    
    RowBox[{"{", 
     RowBox[{
      RowBox[{"NetPort", "[", "\"\<Input\>\"", "]"}], "->", 
      RowBox[{"\"\<model\>\"", "->", 
       RowBox[{"\"\<pooling\>\"", "->", "\"\<normalize\>\""}]}]}], "}"}]}], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.987232221261615*^9, 3.987232221263739*^9}, {
   3.987232443213873*^9, 3.987232457653507*^9}, {3.987233730660922*^9, 
   3.987233730770987*^9}, 3.987234004614276*^9},
 CellLabel->"In[76]:=",ExpressionUUID->"d667ef68-88a7-4bf2-888f-472792193cbe"]
}, Closed]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["GPT2 (slower)",
 FontSize->15,
 FontVariations->{"Underline"->True},
 FontColor->RGBColor[0., 0., 0.]]], "Subsubsection",
 CellChangeTimes->{{3.9872324853174677`*^9, 3.987232502736926*^9}, {
  3.987232549939611*^9, 3.987232572324007*^9}, {3.9872335242847652`*^9, 
  3.987233525270514*^9}},ExpressionUUID->"592a6890-36a6-4945-8028-\
8d2c126197cc"],

Cell[BoxData[
 RowBox[{"textModel", "=", 
  RowBox[{"NetGraph", "[", 
   RowBox[{
    RowBox[{"<|", 
     RowBox[{
      RowBox[{"\"\<model\>\"", "->", 
       RowBox[{
       "NetModel", "[", "\"\<GPT2 Transformer Trained on WebText Data\>\"", 
        "]"}]}], ",", 
      RowBox[{"\"\<last\>\"", "->", 
       RowBox[{"SequenceLastLayer", "[", "]"}]}], ",", 
      RowBox[{"\"\<normalize\>\"", "->", 
       RowBox[{"FunctionLayer", "[", 
        RowBox[{
         RowBox[{"#", "/", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Sqrt", "[", 
             RowBox[{"Total", "[", 
              RowBox[{"#", "^", "2"}], "]"}], "]"}], "+", 
            RowBox[{"10", "^", 
             RowBox[{"-", "12"}]}]}], ")"}]}], "&"}], "]"}]}]}], "|>"}], ",", 
    
    RowBox[{"{", 
     RowBox[{
      RowBox[{"NetPort", "[", "\"\<Input\>\"", "]"}], "->", 
      RowBox[{"\"\<model\>\"", "->", 
       RowBox[{"\"\<last\>\"", "->", "\"\<normalize\>\""}]}]}], "}"}]}], 
   "]"}]}]], "Input",
 CellChangeTimes->{
  3.987232617729765*^9, {3.987232662767551*^9, 3.987232663148122*^9}, {
   3.987233727271858*^9, 3.9872337274803867`*^9}, 3.9872340069604*^9},
 CellLabel->"In[71]:=",ExpressionUUID->"ba8ff1c9-ca9c-4d39-a72f-2e7dc6d55cfb"]
}, Closed]],

