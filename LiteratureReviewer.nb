 FontSize->36,
 FontWeight->"Bold",
 FontColor->RGBColor[0., 0., 0.]]], "Subtitle",
 CellChangeTimes->{{3.899963859343124*^9, 3.899963864923728*^9}, {
   3.899987107019384*^9, 3.8999871160106163`*^9}, {3.900384093368415*^9, 
