Cell[BoxData[
 RowBox[{
  RowBox[{"(*", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Input", ":", 
     RowBox[{
      RowBox[{"-", "string"}], " ", "combined", " ", "string", " ", "of", " ",
       "words"}]}], ",", 
    RowBox[{
