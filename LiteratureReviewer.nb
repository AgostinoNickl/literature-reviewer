              "&"}], "/@", "purgedTextList"}], "]"}]}], ";", 
          RowBox[{"splitTexts", "=", 
           RowBox[{
            RowBox[{
             RowBox[{"StringSplit", "[", 
              RowBox[{"#", ",", "\"\< \>\""}], "]"}], "&"}], "/@", 
