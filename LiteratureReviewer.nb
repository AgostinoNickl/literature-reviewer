Cell[BoxData[
 RowBox[{
  RowBox[{"(*", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Description", ":", 
     RowBox[{
     "Loads", " ", "all", " ", "necessary", " ", "classifiers", " ", "and", 
      " ", "dictionaries", " ", "from", " ", "the", " ", "specified", " ", 
      "repository", " ", "folder"}]}], ",", " ", 
    RowBox[{"sets", " ", "global", " ", "variables"}], ",", 
    RowBox[{"monitors", " ", "loading", " ", "progress"}], ",", " ", 
    RowBox[{
    "and", " ", "checks", " ", "that", " ", "all", " ", "required", " ", 
     "expressions", " ", "were", " ", "loaded", " ", 
     RowBox[{"successfully", "."}]}]}], "*)"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{"ImportFromGithub", ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"status", ",", "inputs"}], "}"}], ",", "\n", 
     RowBox[{
      RowBox[{"Monitor", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"status", "=", "\"\<Loading dependencies (1/3)\>\""}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"dict", "=", 
          RowBox[{"Import", "[", 
           RowBox[{
           "\"\<https://github.com/AgostinoNickl/clipedia/raw/refs/heads/main/\
code/dictionaries/230724_dictFull.wxf\>\"", ",", "\"\<WXF\>\""}], "]"}]}], 
         ";", "\[IndentingNewLine]", 
         RowBox[{"status", "=", "\"\<Loading dependencies (2/3)\>\""}], ";", 
         "\n", 
         RowBox[{"dictReverse", "=", 
          RowBox[{"Import", "[", 
           RowBox[{
           "\"\<https://github.com/AgostinoNickl/clipedia/raw/refs/heads/main/\
code/dictionaries/230724_dictFullReverse.wxf\>\"", ",", "\"\<WXF\>\""}], 
           "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"status", "=", "\"\<Loading dependencies (3/3)\>\""}], ";", 
         "\n", 
         RowBox[{"refClassifier", "=", 
          RowBox[{"Import", "[", 
           RowBox[{
           "\"\<https://github.com/AgostinoNickl/clipedia/raw/refs/heads/main/\
code/functions/220704_refClassifier.wxf\>\"", ",", "\"\<WXF\>\""}], "]"}]}], 
         ";"}], ",", "status"}], "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"AnyTrue", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"ByteCount", "[", "#", "]"}], "&"}], "/@", 
           RowBox[{"{", 
            RowBox[{"refClassifier", ",", "dict", ",", "dictReverse"}], 
            "}"}]}], ",", 
          RowBox[{
           RowBox[{"#", "<", "100"}], "&"}]}], "]"}], ",", 
        RowBox[{
        "Print", "[", 
         "\"\<There seems to have been a problem loading one or more of the \
necessary expressions. Check your internet connection and try again.\>\"", 
         "]"}], ",", 
        RowBox[{
        "Print", "[", "\"\<Everything seems to have loaded correctly.\>\"", 
         "]"}]}], "]"}], ";"}]}], "]"}]}]}]], "Input",
