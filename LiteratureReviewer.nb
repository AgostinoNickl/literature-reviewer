                  RowBox[{"tokenKeys", "[", 
                   RowBox[{"[", "g", "]"}], "]"}], "]"}], "]"}], "]"}], ",", 
               RowBox[{"{", 
                RowBox[{"tokenAssoc", "[", 
                 RowBox[{"[", 
                  RowBox[{
                   RowBox[{"tokenKeys", "[", 
                    RowBox[{"[", "g", "]"}], "]"}], ",", "\"\<tokens\>\""}], 
                  "]"}], "]"}], "}"}], ",", 
               RowBox[{"tokenKeys", "[", 
