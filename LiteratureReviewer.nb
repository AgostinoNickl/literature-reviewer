       "quantErrorNormOld", ",", "flag"}], "}"}], ",", 
     RowBox[{
      RowBox[{"somX", "=", 
       RowBox[{"somGrid", "[", 
        RowBox[{"\"\<dimensions\>\"", ",", "\"\<x\>\""}], "]"}]}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"somY", "=", 
       RowBox[{"somGrid", "[", 
        RowBox[{"\"\<dimensions\>\"", ",", "\"\<y\>\""}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"somDim", "=", 
       RowBox[{"somGrid", "[", 
        RowBox[{"\"\<dimensions\>\"", ",", "\"\<dim\>\""}], "]"}]}], ";", 
