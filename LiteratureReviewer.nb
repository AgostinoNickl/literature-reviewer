Cell[BoxData[{
 RowBox[{
  RowBox[{"zoteroCSV", "=", 
   RowBox[{"Import", "[", 
    RowBox[{"SystemDialogInput", "[", 
     RowBox[{"\"\<FileOpen\>\"", ",", "workingFolder"}], "]"}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"zoteroAss", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"AssociationThread", "[", 
      RowBox[{
       RowBox[{"ToLowerCase", "@", 
        RowBox[{"First", "@", "zoteroCSV"}]}], ",", "#"}], "]"}], "&"}], "/@", 
    RowBox[{"Rest", "@", "zoteroCSV"}]}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.987168246483056*^9, 3.987168256124888*^9}, {
